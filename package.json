{
  "name": "boxcc",
  "productName": "boxcc",
  "version": "1.0.0",
  "description": "Box for Clothes Consult - 服装企划多智能体工作台",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "backend:install": "python3.12 -m venv .venv && .venv/bin/python -m pip install -e ./backend",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.boxcc.app",
    "asar": true,
    "asarUnpack": [
      "backend/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  }
}
